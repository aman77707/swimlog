# ─── Server ────────────────────────────────────
PORT=3000
APP_URL=https://your-app.railway.app

# ─── Database (SQLite) ──────────────────────────
# Mount a Railway volume at /data for persistence
DB_PATH=./data/swimlog.db

# ─── Email (SMTP) ───────────────────────────────
# Gmail example: use an App Password (not your account password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<sendersemail>
SMTP_PASS=<apppassword>
SMTP_FROM=<Senderdisplayname>

# ─── Admin ──────────────────────────────────────
# Used to manually trigger emails via POST /api/trigger-emails
# Header: x-api-key: <value>
ADMIN_KEY=change-this-to-a-secret-value
